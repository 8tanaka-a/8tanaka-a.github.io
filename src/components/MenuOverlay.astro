---
import { Image } from 'astro:assets';
import lightSvg from '../assets/svg/light.svg';
import darkSvg from '../assets/svg/dark.svg';

const items = [
  { label: 'Top', href: '/', accent: '--color-text' },
  { label: 'About', href: '/about', accent: '--color-accent-orange' },
  { label: 'Works', href: '/works/01', accent: '--color-accent-blue' },
  { label: 'Notes', href: '/notes', accent: '--color-accent-green' },
];
---

<div id="menu-overlay" class="overlay" data-menu-overlay aria-hidden="true">
  <nav class="menu" aria-label="メインナビゲーション">
    <ul class="menu-list">
      {
        items.map((item) => (
          <li>
            <a
              href={item.href}
              class="menu-card"
              data-menu-link
              style={`--card-accent: var(${item.accent})`}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="menu-github-item">
        <a
          href="https://github.com/8tanaka-a"
          target="_blank"
          rel="noopener noreferrer"
          class="menu-card menu-github"
          data-menu-link
          style="--card-accent: var(--color-text)"
        >
          GitHub
        </a>
      </li>
    </ul>

    <div class="theme-toggle" role="group" aria-label="テーマ切替">
      <button type="button" class="theme-button is-active" aria-pressed="true" data-theme="light">
        <Image src={lightSvg} alt="ライトモード" class="theme-icon" loading="eager" />
      </button>
      <button type="button" class="theme-button" aria-pressed="false" data-theme="dark">
        <Image src={darkSvg} alt="ダークモード" class="theme-icon" loading="eager" />
      </button>
    </div>
  </nav>
</div>

<script>
  import gsap from 'gsap';
  import { navigate } from 'astro:transitions/client';

  const OPEN_EVENT = 'menu:open';
  const CLOSE_EVENT = 'menu:close';

  type WindowFlag = Window & { __menuNavigating?: boolean };

  function init() {
    const overlay = document.querySelector<HTMLElement>('[data-menu-overlay]');
    if (!overlay || overlay.dataset.initialized === 'true') return;
    overlay.dataset.initialized = 'true';

    const cards = Array.from(overlay.querySelectorAll<HTMLElement>('[data-menu-link]'));
    const toggleArea = overlay.querySelector<HTMLElement>('.theme-toggle');
    const animatables = [...cards, toggleArea].filter((el): el is HTMLElement => el !== null);

    let isOpen = false;

    const focusables = (): HTMLElement[] => [
      ...cards,
      ...Array.from(overlay.querySelectorAll<HTMLButtonElement>('.theme-button')),
    ];

    const open = () => {
      if (isOpen) return;
      isOpen = true;
      overlay.setAttribute('aria-hidden', 'false');
      overlay.classList.add('is-open');
      document.body.style.overflow = 'hidden';

      gsap.killTweensOf(animatables);
      gsap.set(animatables, { opacity: 0, y: 16 });
      gsap.to(animatables, {
        opacity: 1,
        y: 0,
        duration: 0.3,
        stagger: 0.06,
        ease: 'power2.out',
        onComplete: () => focusables()[0]?.focus(),
      });
    };

    const close = () => {
      if (!isOpen) return;
      isOpen = false;
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';

      gsap.killTweensOf(animatables);
      gsap.to(animatables, {
        opacity: 0,
        y: 8,
        duration: 0.3,
        stagger: 0.04,
        ease: 'power2.in',
        onComplete: () => {
          overlay.classList.remove('is-open');
          document.querySelector<HTMLButtonElement>('[data-menu-button]')?.focus();
        },
      });
    };

    document.addEventListener(OPEN_EVENT, open);
    document.addEventListener(CLOSE_EVENT, close);

    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') {
        document.dispatchEvent(new CustomEvent(CLOSE_EVENT));
        return;
      }
      if (e.key === 'Tab') {
        const items = focusables();
        if (items.length === 0) return;
        const first = items[0];
        const last = items[items.length - 1];
        const active = document.activeElement;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        document.dispatchEvent(new CustomEvent(CLOSE_EVENT));
      }
    });

    cards.forEach((card) => {
      card.addEventListener('click', (e) => {
        e.preventDefault();
        const href = card.getAttribute('href');
        if (!href) return;
        (window as WindowFlag).__menuNavigating = true;
        navigate(href);
      });
    });

    // 遷移完了後、すでに完成している次ページの上でメニューを fade-out させて閉じる。
    document.addEventListener('astro:after-swap', () => {
      if (!(window as WindowFlag).__menuNavigating || !isOpen) return;
      isOpen = false;
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      gsap.killTweensOf(animatables);
      gsap.to(animatables, {
        opacity: 0,
        y: 24,
        duration: 1,
        stagger: 0.07,
        ease: 'power2.in',
        onComplete: () => {
          overlay.classList.remove('is-open');
          (window as WindowFlag).__menuNavigating = false;
        },
      });
    });

    // TODO: テーマ切替ロジックは後日実装。今は見た目の選択状態のみトグル。
    const themeButtons = Array.from(overlay.querySelectorAll<HTMLButtonElement>('.theme-button'));
    themeButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        themeButtons.forEach((b) => {
          const active = b === btn;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-pressed', String(active));
        });
      });
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    background-color: var(--color-bg);
    pointer-events: none;
    opacity: 0;
  }

  .overlay.is-open {
    pointer-events: auto;
    opacity: 1;
  }

  .menu {
    max-width: 1600px;
    height: 100%;
    margin-inline: auto;
    padding: 8rem 2rem 2rem;
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    grid-template-rows: repeat(10, 1fr);
    gap: 0.75rem;
  }

  .menu-list {
    grid-column: 6 / 11;
    grid-row: 2 / 8;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .menu-github-item {
    display: none;
  }

  @media (max-width: 1199px) {
    .menu {
      padding: calc(var(--header-height-stacked) + 3.25rem) 2rem 1rem;
      grid-template-columns: 1fr;
    }

    .menu-list {
      grid-column: 1;
      grid-row: 1 / 9;
    }
  }

  @media (max-width: 767px) {
    .menu {
      padding: calc(var(--header-height-stacked) + 3.25rem) 0.75rem 1rem;
    }

    /* SP のみヘッダーの GitHub リンクが非表示になるため、メニュー側に GitHub 項目を出して代替する */
    .menu-github-item {
      display: block;
    }
  }

  .menu-card {
    display: flex;
    align-items: center;
    padding: 1.25rem 1.5rem;
    background-color: var(--color-dot);
    color: var(--color-text);
    font-family: var(--font-geo);
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1;
    transition:
      background-color 0.3s,
      color 0.3s;
  }

  .menu-card:hover {
    background-color: var(--card-accent);
    color: var(--color-bg);
  }

  .menu-card:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  .theme-toggle {
    grid-column: 9 / 11;
    grid-row: 10;
    align-self: end;
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (max-width: 1199px) {
    .theme-toggle {
      grid-column: 1;
      grid-row: 10;
    }
  }

  .theme-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.875rem;
    height: 2.875rem;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    transition:
      background-color 0.2s,
      opacity 0.2s;
  }

  .theme-button.is-active {
    background-color: var(--color-dot);
  }

  .theme-button:not(.is-active):hover {
    opacity: 0.6;
  }

  .theme-button:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  .theme-icon {
    display: block;
    width: 1.75rem;
    height: 1.75rem;
  }
</style>
