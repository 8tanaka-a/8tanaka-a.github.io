---
import lightSvgUrl from '../assets/svg/light.svg?url';
import darkSvgUrl from '../assets/svg/dark.svg?url';

const items = [
  { label: 'Top', href: '/', accent: '--color-text' },
  { label: 'About', href: '/about', accent: '--color-accent-orange' },
  { label: 'Works', href: '/works/01', accent: '--color-accent-blue' },
  { label: 'Notes', href: '/notes', accent: '--color-accent-green' },
];
---

<div id="menu-overlay" class="overlay" data-menu-overlay aria-hidden="true">
  <nav class="menu" aria-label="メインナビゲーション">
    <ul class="menu-list">
      {
        items.map((item) => (
          <li>
            <a
              href={item.href}
              class="menu-card"
              data-menu-link
              style={`--card-accent: var(${item.accent})`}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="menu-github-item">
        <a
          href="https://github.com/8tanaka-a"
          target="_blank"
          rel="noopener noreferrer"
          class="menu-card menu-github"
          data-menu-link
          style="--card-accent: var(--color-text)"
        >
          GitHub
        </a>
      </li>
    </ul>

    <div class="theme-toggle" role="group" aria-label="テーマ切替">
      <button
        type="button"
        class="theme-button is-active"
        aria-pressed="true"
        aria-label="ライトモード"
        data-theme="light"
      >
        <span class="theme-icon" style={`--icon-url: url("${lightSvgUrl}")`} aria-hidden="true"
        ></span>
      </button>
      <button
        type="button"
        class="theme-button"
        aria-pressed="false"
        aria-label="ダークモード"
        data-theme="dark"
      >
        <span class="theme-icon" style={`--icon-url: url("${darkSvgUrl}")`} aria-hidden="true"
        ></span>
      </button>
    </div>
  </nav>
</div>

<script>
  import gsap from 'gsap';
  import { navigate } from 'astro:transitions/client';

  const OPEN_EVENT = 'menu:open';
  const CLOSE_EVENT = 'menu:close';

  type Theme = 'light' | 'dark';
  type WindowFlag = Window & { __menuNavigating?: boolean; __themeChoice?: Theme };

  // ユーザーがこのセッションで明示的にテーマを選んだか。永続化はしない (リロードで OS設定に戻る)。
  let manualOverride = false;

  function getCurrentTheme(): Theme {
    return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
  }

  function applyTheme(theme: Theme) {
    document.documentElement.dataset.theme = theme;
    const meta = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
    if (meta) meta.setAttribute('content', theme === 'dark' ? '#1a1a1a' : '#ececec');
  }

  function syncThemeButtons() {
    const current = getCurrentTheme();
    document.querySelectorAll<HTMLButtonElement>('.theme-button').forEach((btn) => {
      const active = btn.dataset.theme === current;
      btn.classList.toggle('is-active', active);
      btn.setAttribute('aria-pressed', String(active));
    });
  }

  function setTheme(theme: Theme) {
    manualOverride = true;
    // BaseLayout の inline script が遷移時に読み取り、data-theme を再適用する
    (window as WindowFlag).__themeChoice = theme;
    applyTheme(theme);
    syncThemeButtons();
    // 他コンポーネント (DotGrid 等) がインライン色をリフレッシュするためのフック
    document.dispatchEvent(new CustomEvent('theme:change', { detail: { theme } }));
  }

  // テーマ自体の再適用は BaseLayout の inline script が行う (リスナー登録順の都合で
  // DotGrid 等よりも先に走らせる必要があるため)。ここではボタンの選択状態だけ同期する。
  document.addEventListener('astro:after-swap', syncThemeButtons);

  // ユーザーが明示的に選択していない時はシステム設定の変化に追従する
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (manualOverride) return;
    const theme: Theme = e.matches ? 'dark' : 'light';
    applyTheme(theme);
    syncThemeButtons();
    document.dispatchEvent(new CustomEvent('theme:change', { detail: { theme } }));
  });

  function init() {
    const overlay = document.querySelector<HTMLElement>('[data-menu-overlay]');
    if (!overlay || overlay.dataset.initialized === 'true') return;
    overlay.dataset.initialized = 'true';

    const cards = Array.from(overlay.querySelectorAll<HTMLElement>('[data-menu-link]'));
    const toggleArea = overlay.querySelector<HTMLElement>('.theme-toggle');
    const animatables = [...cards, toggleArea].filter((el): el is HTMLElement => el !== null);

    let isOpen = false;

    const focusables = (): HTMLElement[] => [
      ...cards,
      ...Array.from(overlay.querySelectorAll<HTMLButtonElement>('.theme-button')),
    ];

    const open = () => {
      if (isOpen) return;
      isOpen = true;
      overlay.setAttribute('aria-hidden', 'false');
      overlay.classList.add('is-open');
      document.body.style.overflow = 'hidden';

      gsap.killTweensOf(animatables);
      gsap.set(animatables, { opacity: 0, y: 16 });
      gsap.to(animatables, {
        opacity: 1,
        y: 0,
        duration: 0.3,
        stagger: 0.06,
        ease: 'power2.out',
        onComplete: () => focusables()[0]?.focus(),
      });
    };

    const close = () => {
      if (!isOpen) return;
      isOpen = false;
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';

      gsap.killTweensOf(animatables);
      gsap.to(animatables, {
        opacity: 0,
        y: 8,
        duration: 0.3,
        stagger: 0.04,
        ease: 'power2.in',
        onComplete: () => {
          overlay.classList.remove('is-open');
          document.querySelector<HTMLButtonElement>('[data-menu-button]')?.focus();
        },
      });
    };

    document.addEventListener(OPEN_EVENT, open);
    document.addEventListener(CLOSE_EVENT, close);

    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') {
        document.dispatchEvent(new CustomEvent(CLOSE_EVENT));
        return;
      }
      if (e.key === 'Tab') {
        const items = focusables();
        if (items.length === 0) return;
        const first = items[0];
        const last = items[items.length - 1];
        const active = document.activeElement;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        document.dispatchEvent(new CustomEvent(CLOSE_EVENT));
      }
    });

    cards.forEach((card) => {
      card.addEventListener('click', (e) => {
        e.preventDefault();
        const href = card.getAttribute('href');
        if (!href) return;
        (window as WindowFlag).__menuNavigating = true;
        navigate(href);
      });
    });

    // 遷移完了後、すでに完成している次ページの上でメニューを fade-out させて閉じる。
    document.addEventListener('astro:after-swap', () => {
      if (!(window as WindowFlag).__menuNavigating || !isOpen) return;
      isOpen = false;
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      gsap.killTweensOf(animatables);
      gsap.to(animatables, {
        opacity: 0,
        y: 24,
        duration: 1,
        stagger: 0.07,
        ease: 'power2.in',
        onComplete: () => {
          overlay.classList.remove('is-open');
          (window as WindowFlag).__menuNavigating = false;
        },
      });
    });

    const themeButtons = Array.from(overlay.querySelectorAll<HTMLButtonElement>('.theme-button'));
    themeButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const theme: Theme = btn.dataset.theme === 'dark' ? 'dark' : 'light';
        setTheme(theme);
      });
    });
    // 初期表示: 現在の data-theme に合わせてボタンの選択状態を同期
    syncThemeButtons();
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    background-color: var(--color-bg);
    pointer-events: none;
    opacity: 0;
    overflow-y: auto;
  }

  .overlay.is-open {
    pointer-events: auto;
    opacity: 1;
  }

  .menu {
    max-width: 1600px;
    min-height: 100%;
    margin-inline: auto;
    padding: 8rem 2rem 2rem;
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    grid-template-rows: repeat(10, 1fr);
    gap: 0.75rem;
  }

  .menu-list {
    grid-column: 6 / 11;
    grid-row: 2 / 8;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .menu-github-item {
    display: none;
  }

  /*
    タブレット/SP では rigid な 10 行 grid をやめて flex-column に切替。
    menu-list はカード分の自然サイズで縦に詰まり、theme-toggle は
    margin-top: auto で下端に押し付ける。これで小型 SP でも縦溢れしない。
  */
  @media (max-width: 1199px) {
    .menu {
      display: flex;
      flex-direction: column;
      padding: calc(var(--header-height-stacked) + 1rem) 2rem 1rem;
      gap: 0.75rem;
    }
  }

  @media (max-width: 767px) {
    .menu {
      padding: calc(var(--header-height-stacked) + 1rem) 0.75rem 1rem;
    }

    /* SP のみヘッダーの GitHub リンクが非表示になるため、メニュー側に GitHub 項目を出して代替する */
    .menu-github-item {
      display: block;
    }
  }

  .menu-card {
    display: flex;
    align-items: center;
    padding: 1.25rem 1.5rem;
    background-color: var(--color-dot);
    color: var(--color-text);
    font-family: var(--font-geo);
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1;
    transition:
      background-color 0.3s,
      color 0.3s;
  }

  .menu-card:hover {
    background-color: var(--card-accent);
    color: var(--color-bg);
  }

  .menu-card:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  .theme-toggle {
    grid-column: 9 / 11;
    grid-row: 10;
    align-self: end;
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (max-width: 1199px) {
    .theme-toggle {
      /* 親が flex-column になるので grid 配置は無効。下端右寄せに変更 */
      margin-top: auto;
      align-self: flex-end;
      justify-self: auto;
    }
  }

  .theme-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.875rem;
    height: 2.875rem;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    transition:
      background-color 0.2s,
      opacity 0.2s;
  }

  .theme-button.is-active {
    background-color: var(--color-dot);
  }

  .theme-button:not(.is-active):hover {
    opacity: 0.6;
  }

  .theme-button:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  .theme-icon {
    display: block;
    width: 1.75rem;
    height: 1.75rem;
    background-image: var(--icon-url);
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }

  /* SVG の fill は #1A1A1A 固定。ダーク時のみ反転して --color-text 相当の明色にする */
  :root[data-theme='dark'] .theme-icon {
    filter: invert(1);
  }
</style>
