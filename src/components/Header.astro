---
interface Props {
  available?: boolean;
  pageTitle?: string;
}

const { available = true, pageTitle } = Astro.props;
---

<header class="header">
  <div class="header-logo">
    <h1>
      <a href="/" class="logo" aria-label="one code トップページ">
        <span class="logo-text"
          ><span class="logo-o">o</span>ne c<span class="logo-o">o</span>de</span
        >
      </a>
    </h1>
    <p class="status">
      <span class="status-label">status:</span>
      <span class="status-value">FREELANCE</span>
      <span class="status-indicator" aria-label={available ? '受注可能' : '受注停止中'}>
        <span class="status-dot" aria-hidden="true"></span>
        <span class="status-availability">{available ? 'AVAILABLE' : 'UNAVAILABLE'}</span>
      </span>
    </p>
  </div>
  {pageTitle && <h2 class="header-page-title">{pageTitle}</h2>}
  <nav class="header-nav" aria-label="ヘッダーナビゲーション">
    <button type="button" class="menu-button" aria-label="メニューを開く" aria-expanded="false">
      <span class="menu-icon" aria-hidden="true"></span>
    </button>
    <a
      href="https://github.com/8tanaka-a"
      target="_blank"
      rel="noopener noreferrer"
      class="github-link"
      aria-label="GitHub プロフィール (新しいタブで開きます)"
    >
      GitHub
    </a>
  </nav>
</header>

<script>
  import gsap from 'gsap';

  const dot = document.querySelector('.status-dot');
  if (dot) {
    const blink = () => {
      const duration = 0.01 + Math.random() * 0.03;
      const delay = 0.1 + Math.random() * 1;
      gsap.to(dot, {
        opacity: 0.2,
        duration,
        yoyo: true,
        repeat: 1,
        delay,
        onComplete: blink,
      });
    };
    blink();
  }
</script>

<style>
  .header {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    align-items: start;
    padding-top: 2rem;
  }

  .header-logo {
    grid-column: 1 / 4;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .logo {
    display: inline-block;
  }

  .logo-text {
    font-family: var(--font-geo);
    font-weight: 500;
    letter-spacing: -0.01em;
    font-size: 2.8125rem; /* 45px */
    line-height: 1;
    color: var(--color-text);
  }

  .logo-o {
    color: var(--color-accent-orange);
  }

  .status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-text);
  }

  .status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin: 0 0 0 1rem;
  }

  .status-dot {
    display: inline-block;
    width: 0.75rem;
    height: 0.75rem;
    margin: 0 0 2px;
    background-color: var(--color-accent-green);
  }

  .status-availability {
    color: var(--color-accent-green);
  }

  .header-page-title {
    grid-column: 6 / 8;
    font-family: var(--font-geo);
    font-size: 2.8125rem; /* 45px */
    line-height: 1;
    color: var(--color-text);
  }

  .header-nav {
    grid-column: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.96875rem; /* 63.5px */
    height: 2.21875rem; /* 35.5px */
    background-color: var(--color-gray);
    font-family: var(--font-geo);
    font-size: 1rem; /* 16px */
    color: var(--color-bg);
    transition: opacity 0.2s;
  }

  .github-link:hover {
    opacity: 0.7;
  }

  .menu-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.21875rem; /* 35.5px */
    height: 2.21875rem; /* 35.5px */
    border: none;
    background: none;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .menu-button:hover {
    opacity: 0.7;
  }

  .menu-icon {
    position: relative;
    display: block;
    width: 20px;
    height: 1px;
    background-color: var(--color-text);
  }

  .menu-icon::before,
  .menu-icon::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-text);
  }

  .menu-icon::before {
    top: -7px;
  }

  .menu-icon::after {
    top: 7px;
  }
</style>
