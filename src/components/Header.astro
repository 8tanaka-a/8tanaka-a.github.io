---
interface Props {
  available?: boolean;
}

const { available = true } = Astro.props;
---

<header class="header">
  <div class="header-logo">
    <h1>
      <a href="/" class="logo" aria-label="one code トップページ">
        <span class="logo-text"
          ><span class="logo-o">o</span>ne c<span class="logo-o">o</span>de</span
        >
      </a>
    </h1>
    <p class="status">
      <span class="status-label">status:</span>
      <span class="status-value">FREELANCE</span>
      <span class="status-indicator" aria-label={available ? '受注可能' : '受注停止中'}>
        <span class="status-dot" aria-hidden="true"></span>
        <span class="status-availability">{available ? 'AVAILABLE' : 'UNAVAILABLE'}</span>
      </span>
    </p>
  </div>
  <nav class="header-nav" aria-label="ヘッダーナビゲーション">
    <button
      type="button"
      class="menu-button"
      data-menu-button
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="menu-overlay"
    >
      <span class="menu-icon" aria-hidden="true"></span>
    </button>
    <a
      href="https://github.com/8tanaka-a"
      target="_blank"
      rel="noopener noreferrer"
      class="github-link"
      aria-label="GitHub プロフィール (新しいタブで開きます)"
    >
      GitHub
    </a>
  </nav>
</header>

<script>
  import gsap from 'gsap';

  let blinkTween: gsap.core.Tween | null = null;
  let currentSetState: ((open: boolean) => void) | null = null;
  let documentListenersAttached = false;

  function setupBlink() {
    const dot = document.querySelector('.status-dot');
    if (!dot) return;
    blinkTween?.kill();
    const blink = () => {
      const duration = 0.01 + Math.random() * 0.03;
      const delay = 0.1 + Math.random() * 1;
      blinkTween = gsap.to(dot, {
        opacity: 0.2,
        duration,
        yoyo: true,
        repeat: 1,
        delay,
        onComplete: blink,
      });
    };
    blink();
  }

  function setupMenuButton() {
    const button = document.querySelector<HTMLButtonElement>('[data-menu-button]');
    if (!button) return;

    let isOpen = false;
    const setState = (open: boolean) => {
      isOpen = open;
      button.classList.toggle('is-open', open);
      button.setAttribute('aria-expanded', String(open));
      button.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');
    };
    currentSetState = setState;

    button.addEventListener('click', () => {
      const next = !isOpen;
      setState(next);
      document.dispatchEvent(new CustomEvent(next ? 'menu:open' : 'menu:close'));
    });

    if (!documentListenersAttached) {
      documentListenersAttached = true;
      document.addEventListener('menu:close', () => currentSetState?.(false));
      document.addEventListener('astro:before-preparation', () => currentSetState?.(false));
    }
  }

  setupBlink();
  setupMenuButton();
  document.addEventListener('astro:after-swap', () => {
    setupBlink();
    setupMenuButton();
  });
</script>

<style>
  .header {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    align-items: start;
    padding-top: 2rem;
  }

  @media (max-width: 768px) {
    .header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      grid-template-columns: 1fr auto;
      padding: 1.5rem 0.75rem 0.75rem;
      background-color: var(--color-bg);
      z-index: 60;
    }
  }

  .header-logo {
    grid-column: 1 / 4;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  @media (max-width: 768px) {
    .header-logo {
      grid-column: 1;
    }
  }

  .logo {
    display: block;
    line-height: 0.8;
  }

  .logo-text {
    display: flex;
    font-family: var(--font-geo);
    font-weight: 500;
    letter-spacing: -0.03em;
    font-size: 2.8125rem; /* 45px */
    color: var(--color-text);
  }

  .logo-o {
    display: block;
    color: var(--color-accent-orange);
  }

  .status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-text);
  }

  .status-value {
    margin-right: 1rem;
  }

  .status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
  }

  /* 狭い SP で status が幅オーバーした時に改行できるように */
  @media (max-width: 768px) {
    .status {
      flex-wrap: wrap;
      row-gap: 0.25rem;
    }
  }

  .status-dot {
    display: inline-block;
    width: 0.75rem;
    height: 0.75rem;
    margin: 0 0 2px;
    background-color: var(--color-accent-green);
  }

  .status-availability {
    color: var(--color-accent-green);
  }

  .header-nav {
    grid-column: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .github-link {
    position: relative;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.96875rem; /* 63.5px */
    height: 2.21875rem; /* 35.5px */
    background-color: var(--color-gray);
    font-family: var(--font-geo);
    font-size: 1rem; /* 16px */
    color: var(--color-bg);
    transition: opacity 0.2s;
  }

  .github-link:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .header-nav {
      grid-column: 2;
    }

    .github-link {
      display: none;
    }
  }

  .menu-button {
    position: relative;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.21875rem; /* 35.5px */
    height: 2.21875rem; /* 35.5px */
    border: none;
    background: none;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .menu-button:hover {
    opacity: 0.7;
  }

  .menu-icon {
    position: relative;
    display: block;
    width: 20px;
    height: 1px;
    background-color: var(--color-text);
    transition:
      background-color 0.2s,
      transform 0.2s ease;
  }

  .menu-icon::before,
  .menu-icon::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-text);
    transition: transform 0.2s ease;
  }

  .menu-icon::before {
    top: -7px;
  }

  .menu-icon::after {
    top: 7px;
  }

  .menu-button.is-open .menu-icon {
    background-color: transparent;
  }

  .menu-button.is-open .menu-icon::before {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-button.is-open .menu-icon::after {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>
