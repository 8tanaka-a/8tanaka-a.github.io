---
import BaseLayout from '../layouts/BaseLayout.astro';
import DotGrid from '../components/DotGrid.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

/** About ページのハイライトパターン（"@" 記号） */
const highlightedCells: [number, number][] = [
  // 上辺
  [2, 2],
  [3, 2],
  [4, 2],
  [5, 2],
  [6, 2],
  // 左右の柱
  [1, 3],
  [7, 3],
  [1, 4],
  [7, 4],
  [1, 5],
  [7, 5],
  [1, 6],
  [7, 6],
  [1, 7],
  [7, 7],
  // 下辺
  [2, 8],
  [3, 8],
  [4, 8],
  [5, 8],
  [6, 8],
  // 内側 "a"
  [4, 4],
  [5, 4],
  [3, 5],
  [5, 5],
  [3, 6],
  [4, 6],
  [5, 6],
];

/** アニメーション順序: 内側反時計回り → 外側反時計回り */
const animationSequence: [number, number][][] = [
  // 内側 "a" 反時計回り (上→左→下→右)
  [[5, 4]],
  [[4, 4]],
  [[3, 5]],
  [[3, 6]],
  [[4, 6]],
  [[5, 6]],
  [[5, 5]],
  // 外側 反時計回り (上→左→下→右)
  [[6, 2]],
  [[5, 2]],
  [[4, 2]],
  [[3, 2]],
  [[2, 2]],
  [[1, 3]],
  [[1, 4]],
  [[1, 5]],
  [[1, 6]],
  [[1, 7]],
  [[2, 8]],
  [[3, 8]],
  [[4, 8]],
  [[5, 8]],
  [[6, 8]],
  [[7, 7]],
  [[7, 6]],
  [[7, 5]],
  [[7, 4]],
  [[7, 3]],
];

/** 内側(7ウェーブ)はゆっくり、外側(残り)は速く */
const staggerInterval = [...Array(7).fill(0.05), ...Array(animationSequence.length - 7).fill(0.03)];

const breadcrumbs = [{ label: 'Top', href: '/' }, { label: 'About' }];
---

<BaseLayout
  title="About | one code"
  description="フリーランスフロントエンドエンジニア「one code」の自己紹介。"
>
  <main id="main" class="about-main">
    <div class="dot-grid-area">
      <DotGrid
        highlightedCells={highlightedCells}
        animationSequence={animationSequence}
        staggerInterval={staggerInterval}
      />
    </div>

    <div class="about-lead-group">
      <h2 class="about-role">Frontend Engineer</h2>
      <p class="about-lead">作ることが好きです。</p>
    </div>

    <div class="about-body-wrap">
      <p class="about-body">
        わからないことが、少しずつわかっていく過程が、特におもしろいです。<br />
        <br />
        エラーが出るたびに少し強くなる。<br />そういう感覚で作ってきました。<br />
        <br />
        最近はAI駆動開発を実践しています。<br />まだまだ勉強中で、毎日新しい気づきがあります。<br />
        <br />
        もっと速く、もっと質高く作れるか、これからも試します。
      </p>
    </div>

    <div class="breadcrumb-area">
      <Breadcrumb items={breadcrumbs} />
    </div>
  </main>
</BaseLayout>

<style>
  .about-main {
    grid-column: 1 / -1;
    grid-row: 2;
    display: grid;
    grid-template-columns: subgrid;
    grid-template-rows: repeat(10, 1fr);
    gap: 0.75rem;
    padding-bottom: 2rem;
  }

  .dot-grid-area {
    grid-column: 1 / 5;
    grid-row: 1 / -1;
    align-self: end;
  }

  .about-lead-group {
    grid-column: 6 / 11;
    grid-row: 2 / 4;
  }

  .about-body-wrap {
    grid-column: 6 / 11;
    grid-row: 4 / 9;
  }

  .about-role {
    font-family: var(--font-mono);
    font-size: 2.25rem; /* 36px */
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-text);
    margin: 0;
  }

  .about-lead {
    font-family: var(--font-sans);
    font-size: 1.25rem; /* 20px */
    color: var(--color-text);
    margin: 12px 0 0;
  }

  .about-body {
    font-family: var(--font-sans);
    font-size: 1rem; /* 16px */
    line-height: 1.75; /* 28px */
    letter-spacing: 0.08em;
    color: var(--color-text);
    margin: 0;
  }

  .breadcrumb-area {
    grid-column: 9 / 11;
    grid-row: 10;
    align-self: end;
    justify-self: end;
  }

  @media (max-width: 1199px) {
    .about-main {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding-top: 3.25rem;
      padding-bottom: 1rem;
    }

    .about-lead-group {
      order: 1;
    }

    .dot-grid-area {
      order: 2;
      align-self: end;
      width: 50vw;
      margin-bottom: 2.5rem; /* gap 1.5rem + 2.5rem = 4rem (64px) */
    }

    .about-body-wrap {
      order: 3;
    }

    .about-role {
      font-size: 1.5rem; /* 24px */
    }

    .about-lead {
      font-size: 1.125rem; /* 18px */
    }

    .breadcrumb-area {
      order: 4;
      align-self: end;
      margin-top: 2rem;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const isStacked = () => window.matchMedia('(max-width: 1199px)').matches;

  function enterAnimation() {
    if ((window as Window & { __menuNavigating?: boolean }).__menuNavigating) return;
    if (isStacked()) return;
    const targets = ['.about-role', '.about-lead', '.about-body', '.breadcrumb-area'];
    const elements = targets.map((sel) => document.querySelector(sel)).filter((el) => el !== null);
    if (elements.length === 0) return;

    gsap.set(elements, { opacity: 0, y: 16 });
    gsap.to(elements, {
      opacity: 1,
      y: 0,
      duration: 0.4,
      stagger: 0.08,
      ease: 'power2.out',
      delay: 0.15,
    });
  }

  function setupExitAnimation() {
    document.addEventListener('astro:before-preparation', (e) => {
      if ((window as Window & { __menuNavigating?: boolean }).__menuNavigating) return;
      if (isStacked()) return;
      const main = document.querySelector('.about-main');
      if (!main || !('loader' in e)) return;

      const targets = ['.breadcrumb-area', '.about-body', '.about-lead', '.about-role'];
      const elements = targets.map((sel) => main.querySelector(sel)).filter((el) => el !== null);

      if (elements.length === 0) return;

      const event = e as Event & { loader: () => Promise<void> };
      const originalLoader = event.loader;
      event.loader = async () => {
        await Promise.all([
          originalLoader(),
          new Promise<void>((resolve) => {
            gsap.to(elements, {
              opacity: 0,
              y: 10,
              duration: 0.2,
              stagger: 0.02,
              ease: 'power2.in',
              onComplete: resolve,
            });
          }),
        ]);
      };
    });
  }

  enterAnimation();
  setupExitAnimation();
  document.addEventListener('astro:after-swap', enterAnimation);
</script>
