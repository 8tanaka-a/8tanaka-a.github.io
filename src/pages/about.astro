---
import BaseLayout from '../layouts/BaseLayout.astro';
import DotGrid from '../components/DotGrid.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

/** About ページのハイライトパターン（後で指定） */
const highlightedCells: [number, number][] = [];

/** アニメーション順序（後で指定） */
const animationSequence: [number, number][][] = [];

const breadcrumbs = [{ label: 'Top', href: '/' }, { label: 'About' }];
---

<BaseLayout title="About | one code">
  <main id="main" class="about-main">
    <div class="dot-grid-area">
      <DotGrid highlightedCells={highlightedCells} animationSequence={animationSequence} />
    </div>

    <div class="about-content">
      <h3 class="about-role">Frontend Engineer</h3>
      <p class="about-lead">作るのことが好きです。</p>

      <p class="about-body">
        わからないことが、少しずつわかっていく過程が、特におもしろいです。<br />
        <br />
        エラーが出るたびに少し強くなる。<br />そういう感覚で作ってきました。<br />
        <br />
        最近はAI駆動開発を実践しています。<br />まだまだ勉強中で、毎日新しい気づきがあります。<br />
        <br />
        もっと速く、もっと質高く作れるか、これからも試します。
      </p>
    </div>

    <div class="breadcrumb-area">
      <Breadcrumb items={breadcrumbs} />
    </div>
  </main>
</BaseLayout>

<style>
  .about-main {
    grid-column: 1 / -1;
    grid-row: 2;
    display: grid;
    grid-template-columns: subgrid;
    grid-template-rows: repeat(10, 1fr);
    gap: 0.75rem;
    padding-bottom: 2rem;
  }

  .dot-grid-area {
    grid-column: 1 / 5;
    grid-row: 1 / -1;
    align-self: end;
  }

  .about-content {
    grid-column: 6 / 11;
    grid-row: 3 / 9;
  }

  .about-role {
    font-family: var(--font-mono);
    font-size: 2.25rem; /* 36px */
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-text);
    margin: 0;
  }

  .about-lead {
    font-family: var(--font-sans);
    font-size: 1.25rem; /* 20px */
    color: var(--color-text);
    margin: 12px 0 0;
  }

  .about-body {
    font-family: var(--font-sans);
    font-size: 1rem; /* 16px */
    line-height: 1.75; /* 28px */
    letter-spacing: 0.08em;
    color: var(--color-text);
    margin: 120px 0 0;
  }

  .breadcrumb-area {
    grid-column: 9 / 11;
    grid-row: 10;
    align-self: end;
    justify-self: end;
  }
</style>
