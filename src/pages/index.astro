---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DotGrid from '../components/DotGrid.astro';
import arrowSvgUrl from '../assets/svg/arrow.svg?url';
import { works } from '../data/works';

/** トップページのハイライトパターン（"=>" 矢印） */
const highlightedCells: [number, number][] = [
  [4, 2],
  [5, 3],
  [1, 4],
  [2, 4],
  [3, 4],
  [6, 4],
  [7, 5],
  [1, 6],
  [2, 6],
  [3, 6],
  [6, 6],
  [5, 7],
  [4, 8],
];

/** アニメーション順序: "=" 左→右, ">" 頂点→外側 */
const animationSequence: [number, number][][] = [
  [
    [1, 4],
    [1, 6],
  ],
  [
    [2, 4],
    [2, 6],
  ],
  [
    [3, 4],
    [3, 6],
  ],
  [[7, 5]],
  [
    [6, 4],
    [6, 6],
  ],
  [
    [5, 3],
    [5, 7],
  ],
  [
    [4, 2],
    [4, 8],
  ],
];

const notesEntries = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const formatDate = (date: Date) => {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}/${m}/${d}`;
};

const notes = notesEntries.map((entry) => ({
  date: formatDate(entry.data.date),
  title: entry.data.title,
  href: `/notes/${entry.id}`,
}));
---

<BaseLayout
  title="one code | Frontend Engineer"
  description="フリーランスフロントエンドエンジニア「one code」のポートフォリオ。実績・記事・自己紹介を掲載。"
>
  <main id="main" class="top-main" style={`--arrow-url: url('${arrowSvgUrl}')`}>
    <div class="dot-grid-area">
      <DotGrid highlightedCells={highlightedCells} animationSequence={animationSequence} />
    </div>

    <section class="about-section">
      <h2 class="section-title about-title">About</h2>
      <a href="/about" class="card about-card">
        <span class="card-text">
          <span class="about-role">Frontend Engineer</span>
          <span class="about-desc">作ることが好きです。</span>
        </span>
      </a>
    </section>

    <section class="works-section">
      <h2 class="section-title works-title">Works</h2>
      <div class="carousel works-carousel">
        {
          works.map((work, i) => (
            <a href={`/works/${work.slug}`} class={`card work-card work-${i + 1}`}>
              <span class="card-text">
                <span class="work-number">{work.number}</span>
                <span class="work-name">{work.title}</span>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="notes-section">
      <h2 class="section-title notes-title">Notes</h2>
      <div class="carousel notes-carousel">
        {
          notes.map((note, i) => (
            <a href={note.href} class={`card note-card note-${i + 1}`}>
              <span class="card-text">
                <span class="note-date">{note.date}</span>
                <span class="note-title">{note.title}</span>
              </span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /*
    PC レイアウトでは GSAP enter が opacity:0 → 1 でフェードインさせるため、
    新ページ描画時に一瞬 opacity:1 でフラッシュしないよう CSS で初期非表示にする。
  */
  @media (min-width: 1200px) {
    .about-title,
    .about-card,
    .works-title,
    .work-card,
    .notes-title,
    .note-card {
      opacity: 0;
    }
  }

  .top-main {
    grid-column: 1 / -1;
    grid-row: 2;
    display: grid;
    grid-template-columns: subgrid;
    grid-template-rows: repeat(10, 1fr);
    gap: 0.75rem;
    padding-bottom: 2rem;
  }

  /* PC: section と carousel ラッパーを透過させて子要素を直接 grid に流す */
  .about-section,
  .works-section,
  .notes-section,
  .carousel {
    display: contents;
  }

  /*
    10列 × 10行グリッド:
    col 1-4 : DotGrid (4列)
    col 5-6 : About (2列 × 4行)
    col 7-8 : Works (2列 × 2行 each)
    col 9-10: Notes (2列)
  */

  /* --- DotGrid --- */
  .dot-grid-area {
    grid-column: 1 / 5;
    grid-row: 1 / -1;
    align-self: end;
  }

  /* --- Section titles --- */
  .section-title {
    font-family: var(--font-geo);
    font-size: 2.8125rem;
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-text);
    margin: 0;
  }

  .works-title {
    grid-column: 7 / 8;
    grid-row: 2;
    align-self: end;
  }

  .about-title {
    grid-column: 5 / 7;
    grid-row: 6;
    align-self: end;
  }

  .notes-title {
    grid-column: 9 / 11;
    grid-row: 4;
    align-self: end;
  }

  /* --- Cards (共通) --- */
  .card {
    position: relative;
    display: flex;
    align-items: flex-end;
    background-color: var(--color-dot);
    padding: 0.75rem;
    color: var(--color-text);
    transition:
      background-color 0.3s,
      color 0.3s;
    overflow: hidden;
  }

  .card::after {
    content: '';
    position: absolute;
    right: 0.75rem;
    bottom: 1rem;
    width: 0.7rem;
    height: 0.7rem;
    background-color: #fff;
    mask-image: var(--arrow-url);
    mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-image: var(--arrow-url);
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .card:hover::after {
    opacity: 1;
  }

  .card:hover {
    color: var(--color-bg);
  }

  .card:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  .card-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .work-card .card-text {
    flex-direction: row;
    gap: 0.5rem;
  }

  /* --- Works (2列 × 2行) --- */
  .work-card:hover {
    background-color: var(--color-accent-blue);
  }

  .work-card {
    grid-column: 7 / 9;
  }

  .work-1 {
    grid-row: 3 / 5;
  }
  .work-2 {
    grid-row: 5 / 7;
  }
  .work-3 {
    grid-row: 7 / 9;
  }
  .work-4 {
    grid-row: 9 / 11;
  }

  .work-number {
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .work-name {
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }

  /* --- About (2列 × 4行) --- */
  .about-card:hover {
    background-color: var(--color-accent-orange);
  }

  .about-card {
    grid-column: 5 / 7;
    grid-row: 7 / 11;
  }

  .about-role {
    font-family: var(--font-mono);
    font-size: 1.25rem;
  }

  .about-desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }

  /* --- Notes (2列 × 3行) --- */
  .note-card:hover {
    background-color: var(--color-accent-green);
  }

  .note-card {
    grid-column: 9 / 11;
  }

  .note-1 {
    grid-row: 5 / 8;
  }
  .note-2 {
    grid-row: 8 / 11;
  }

  .note-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .note-title {
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }

  @media (max-width: 1199px) {
    .top-main {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      display: flex;
      flex-direction: column;
      gap: 4rem; /* 64px: セクション間 */
      padding-bottom: 1rem;
    }

    .dot-grid-area {
      display: none;
    }

    .about-section,
    .works-section,
    .notes-section {
      display: flex;
      flex-direction: column;
      gap: 1.5rem; /* 24px: タイトルとカード(群)間 */
    }

    .about-title,
    .works-title,
    .notes-title {
      align-self: stretch;
      text-align: left;
    }

    .about-title {
      color: var(--color-accent-orange);
    }

    .works-title {
      color: var(--color-accent-blue);
    }

    .notes-title {
      color: var(--color-accent-green);
    }

    /* タブレット: works/notes を grid 配置 (SP は下のメディアクエリで上書き) */
    .works-carousel {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }

    .notes-carousel {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    /* PC グリッド用の grid-column/grid-row を解除して子要素を carousel grid に流す */
    .about-card,
    .work-card,
    .note-card {
      grid-column: auto;
      grid-row: auto;
    }

    /* タブレットでは works を 3 件のみ表示 (4 件目以降を非表示にして 3 列で揃える) */
    .work-card:nth-child(n + 4) {
      display: none;
    }

    .about-card {
      aspect-ratio: 4 / 1;
    }

    .work-card,
    .note-card {
      aspect-ratio: 16 / 9;
    }
  }

  @media (max-width: 767px) {
    /* SP: works/notes をカルーセル(横スクロール)に戻す */
    .carousel {
      display: flex;
      gap: 0.75rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-padding-inline-start: 0.75rem;
      scrollbar-width: none;
      margin-inline: -0.75rem;
      padding-inline: 0.75rem;
      grid-template-columns: none;
    }

    .carousel::-webkit-scrollbar {
      display: none;
    }

    /* SP では全カードを About カード幅 (100vw - 余白24px) を 16:9 で算出した高さに統一 */
    .about-card,
    .work-card,
    .note-card {
      aspect-ratio: auto;
      height: calc((100vw - 1.5rem) * 9 / 16);
    }

    .work-card,
    .note-card {
      flex: 0 0 75%;
      scroll-snap-align: start;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const isStacked = () => window.matchMedia('(max-width: 1199px)').matches;

  function setupExitAnimation() {
    document.addEventListener('astro:before-preparation', (e) => {
      if ((window as Window & { __menuNavigating?: boolean }).__menuNavigating) return;
      if (isStacked()) return;
      const main = document.querySelector('.top-main');
      if (!main || !('loader' in e)) return;

      // フェードアウト順: Notes下→上, Works下→上, About
      const targets = [
        '.note-2',
        '.note-1',
        '.notes-title',
        '.work-4',
        '.work-3',
        '.work-2',
        '.work-1',
        '.works-title',
        '.about-card',
        '.about-title',
      ];

      const elements = targets.map((sel) => main.querySelector(sel)).filter((el) => el !== null);

      if (elements.length === 0) return;

      const event = e as Event & { loader: () => Promise<void> };
      const originalLoader = event.loader;
      event.loader = async () => {
        await Promise.all([
          originalLoader(),
          new Promise<void>((resolve) => {
            gsap.to(elements, {
              opacity: 0,
              y: 10,
              duration: 0.2,
              stagger: 0.02,
              ease: 'power2.in',
              onComplete: resolve,
            });
          }),
        ]);
      };
    });
  }

  function enterAnimation() {
    if (isStacked()) return;
    const main = document.querySelector('.top-main');
    if (!main) return;

    // フェードイン順: About, Works上→下, Notes上→下（左から右）
    const targets = [
      '.about-title',
      '.about-card',
      '.works-title',
      '.work-1',
      '.work-2',
      '.work-3',
      '.work-4',
      '.notes-title',
      '.note-1',
      '.note-2',
    ];

    const elements = targets.map((sel) => main.querySelector(sel)).filter((el) => el !== null);
    if (elements.length === 0) return;

    // メニュー経由の遷移ではメニューのフェードアウトが視覚的な遷移なので
    // GSAP のフェードインはスキップ。ただし CSS pre-hide で opacity:0 のままだと
    // メニュー消失後に見えないので opacity:1 を直接当てて可視化する。
    if ((window as Window & { __menuNavigating?: boolean }).__menuNavigating) {
      gsap.set(elements, { opacity: 1, y: 0 });
      return;
    }

    gsap.set(elements, { opacity: 0, y: 16 });
    gsap.to(elements, {
      opacity: 1,
      y: 0,
      duration: 0.25,
      stagger: 0.03,
      ease: 'power2.out',
      delay: 0.1,
    });
  }

  setupExitAnimation();
  document.addEventListener('astro:page-load', enterAnimation);
</script>
